# =============================================================================
# PRODUCTION env template — shared server + EXTERNAL Traefik (docs/07-deployment.md, ADR-017).
# Copy to `.env` ON THE SERVER in /opt/claude-ios and fill from the secret manager.
# NEVER commit the real `.env` (it is gitignored). This `.example` holds PLACEHOLDERS ONLY —
# no real secrets.
#
# All secrets must come from the server's secret manager / env, never baked into the image
# (docs/05-security.md). Generate high-entropy secrets with:  openssl rand -base64 32
#
# Loaded by docker-compose.prod.yml via `env_file: .env` (api + migrate). The image is built
# ON THE SERVER from sources (no registry tag), so there is NO IMAGE/IMAGE_TAG here (ADR-017).
# =============================================================================

# --- Multi-instance identity (ADR-017 §Мульти-инстанс) -----------------------
# docker-compose project name = instance prefix. Substituted as ${COMPOSE_PROJECT_NAME:-claude-ios}
# into the image tags (<proj>-backend:prod) and the Traefik router/service names (routers.<proj>).
# DEFAULT is `claude-ios` == the previous hardcoded value (backward-compat invariant: `compose
# config` is identical when this key is unset). PUBLIC config, not a secret.
#   - Live broadnova.shop: LEAVE UNSET (commented out) -> resolves to `claude-ios` (no-op).
#   - A clone: set to the instance name (e.g. `claude-hermes`) AND deploy with `-p <proj>` so the
#     containers/volumes/default-network are isolated per instance. The shared `web` network and
#     Traefik stay common to all instances.
#   - claude-hermes is a NEW, INDEPENDENT instance (Hermes-per-user control plane) deployed to
#     /opt/claude-hermes. See the ready-to-uncomment §claude-hermes clone block at the BOTTOM of
#     this file (its own SERVICE_DOMAIN, HERMES_DOCKER_NETWORK, fresh secrets).
# COMPOSE_PROJECT_NAME=claude-hermes

# --- Traefik routing (ADR-017) ----------------------------------------------
# Service domain — DUAL role:
#   1) Traefik Host router label Host(`${SERVICE_DOMAIN}`) and the ACME cert (ADR-017).
#   2) Read by the APP (ADR-031) to build the ABSOLUTE site.preview URL
#      https://<SERVICE_DOMAIN>/v1/preview/... so the model copies it verbatim (no host
#      hallucination). Same value, same var — no extra env needed; deploying the new code
#      picks it up since this is already set on both prod instances. Normalized app-side.
# Q-017-1 (resolved): the domain is broadnova.shop. Its A-record MUST point to 87.239.135.154
# BEFORE launch (Traefik's Let's Encrypt ACME challenge). TLS/ACME is issued by the external
# Traefik, not by us. NOTE: this is PUBLIC config, not a secret.
SERVICE_DOMAIN=broadnova.shop
# ACME cert-resolver name configured in the SHARED Traefik (/opt/edge) by the server owner.
# Q-017-2 (resolved): the resolver name is `le` (default on the websecure entrypoint).
# PUBLIC config, not a secret.
TRAEFIK_CERTRESOLVER=le

# --- Database / Redis --------------------------------------------------------
# In-compose service names (internal `default` network). Credentials below MUST match
# POSTGRES_* (provisioned secrets).
# CLONE NOTE (ADR-017 §Мульти-инстанс): a clone's DATABASE_URL MUST reference its OWN
# POSTGRES_USER / POSTGRES_DB / POSTGRES_PASSWORD (a fresh `openssl rand -base64 32` password —
# never reuse a sibling instance's DB or credentials; volumes are isolated per project name).
# ADR-053 (durable append-only audit_logs): runtime and migrations use SEPARATE DB roles so
# audit_logs is tamper-resistant at the DB layer.
#   DATABASE_URL          -> runtime role app_rw      (least-privilege; api process). On
#                            audit_logs: only INSERT,SELECT (migration 0016 REVOKEs the rest).
#   DATABASE_URL_MIGRATE  -> migration role app_migrate (full DDL). Used ONLY by the `migrate`
#                            job (`run --rm migrate`); env.py prefers it, falling back to DATABASE_URL.
# Both DSNs target the in-compose `postgres` service. Embed each role's OWN password.
DATABASE_URL=postgresql+asyncpg://app_rw:<app_rw_password>@postgres:5432/<db_name>
DATABASE_URL_MIGRATE=postgresql+asyncpg://app_migrate:<app_migrate_password>@postgres:5432/<db_name>
REDIS_URL=redis://redis:6379/0
# Postgres container bootstrap creds — REAL secrets in prod (secret manager). POSTGRES_USER is the
# cluster superuser/owner used at init; the app does NOT connect as this role at runtime (ADR-053).
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=<db_password>
POSTGRES_DB=<db_name>
# ADR-053 role passwords (REAL secrets via secret manager; high-entropy, per-instance — never
# reuse across instances or with POSTGRES_PASSWORD). Consumed by docker/postgres/init/01-roles.sh
# on a FRESH pgdata volume. ⚠️ On an EXISTING prod DB the init script does NOT run — apply the
# roles MANUALLY (docs/07-deployment.md §Роли БД, "CREATE ROLE — prod (existing DB)"). These MUST
# match the passwords embedded in DATABASE_URL (app_rw) / DATABASE_URL_MIGRATE (app_migrate) above.
APP_RW_PASSWORD=<app_rw_password>
APP_MIGRATE_PASSWORD=<app_migrate_password>

# --- LLM provider selection (ADR-033) ----------------------------------------
# Which LLM provider the orchestration uses: `anthropic` | `openai`. PER-INSTANCE, PUBLIC (not a
# secret). DEFAULT `anthropic` == current behaviour: anthropic instances (claude-ios/broadnova,
# avelyra) LEAVE THIS UNSET (commented) -> resolves to `anthropic` (no-op, compose/behaviour
# unchanged). On the OpenAI instances (3rd orvianix, 4th veltrio) set `LLM_PROVIDER=openai`.
#   - LLM_PROVIDER=anthropic -> the ANTHROPIC_* block below is used (OPENAI_* ignored).
#   - LLM_PROVIDER=openai    -> the OPENAI_* block below is used (ANTHROPIC_* ignored).
# LLM_PROVIDER=anthropic

# --- Anthropic (mode=credits). Used when LLM_PROVIDER=anthropic (default). --------------------
# Real key WITH positive balance (prod-checklist, ready). SECRET, per-instance.
ANTHROPIC_API_KEY=<anthropic_api_key>
ANTHROPIC_MODEL=claude-sonnet-4-5
# Output token budget per call (ADR-025). 16000 prevents truncation of code/file generation
# (stop_reason=max_tokens). Per-instance — set on EVERY instance (broadnova, avelyra). Non-streaming.
ANTHROPIC_MAX_TOKENS=16000
# Raised to 120 (ADR-025) for long non-streaming generation at 16000 tokens.
ANTHROPIC_TIMEOUT_SECONDS=120
ANTHROPIC_MAX_RETRIES=2

# --- OpenAI (mode=credits). Used when LLM_PROVIDER=openai (3rd instance, ADR-033). -----------
# Set this whole block ONLY on the OpenAI instances (orvianix, veltrio). On anthropic instances leave it
# unset/commented (ANTHROPIC_* is used instead).
# OPENAI_API_KEY — SECRET, secret manager only, under redaction. REQUIRED when LLM_PROVIDER=openai.
#   PER-INSTANCE: own key with positive balance; NEVER share across instances. NEVER commit a real
#   value (placeholder below). On anthropic instances this is not set.
OPENAI_API_KEY=<openai_api_key>
# Default orchestration model (Chat Completions API, non-streaming). Default gpt-4o.
OPENAI_MODEL=gpt-4o
# Output token budget per call. Default 16000 (parity with ANTHROPIC_MAX_TOKENS).
OPENAI_MAX_TOKENS=16000
# Upstream call timeout, seconds. Default 120.
OPENAI_TIMEOUT_SECONDS=120
# SDK retries. Default 2.
OPENAI_MAX_RETRIES=2
# Active model returned in the BYOK response (activeModel) when keyStatus=valid (ADR-016/ADR-033).
# Separate from anthropic BYOK_DEFAULT_MODEL. Default gpt-4o.
OPENAI_BYOK_DEFAULT_MODEL=gpt-4o

# --- JWT (RS256) — embedded issuer (ADR-018) ---------------------------------
# The backend signs and verifies its own RS256 tokens. Generate an RSA keypair on the
# server (openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt_private.pem;
# openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem), mount via .secrets/ and point
# the *_PATH vars at them. Without a private key /v1/auth/* returns 503 (verify still works).
JWT_ISSUER=https://broadnova.shop
JWT_AUDIENCE=claude-ios
JWT_KID=mvp-key-1
# Keys by file path (recommended) — mounted read-only into the api container (.secrets/).
JWT_PRIVATE_KEY_PATH=/app/.secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/app/.secrets/jwt_public.pem
# Alternative inline PEM (\n-escaped, single line); leave empty when using *_PATH.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# External-IdP verify-only mode (Apple/Firebase) — leave empty for embedded issuer.
JWT_JWKS_URL=
# Token TTLs (embedded issuer).
AUTH_ACCESS_TTL_SECONDS=3600
AUTH_REFRESH_TTL_SECONDS=2592000
AUTH_RATE_LIMIT_PER_IP=10

# --- KMS envelope encryption for BYOK (ADR-003, LocalKmsClient on MVP) -------
# High-entropy 32-byte master key, base64. SECRET — secret manager only, under redaction.
# KMS_KEY_ID is EMPTY on MVP (LocalKmsClient, in-process AES-256-GCM wrap; no cloud KMS yet —
# Q-002-1). A clone uses its OWN fresh KMS_LOCAL_MASTER_KEY (BYOK ciphertext is NOT portable
# between instances, by design — ADR-003 §Мульти-инстанс clone contract).
KMS_KEY_ID=
KMS_LOCAL_MASTER_KEY=<base64-32-random-bytes>

# --- App Store Server API (Q-007-1) ------------------------------------------
# must-configure-before-launch: production posture + Apple root CA + real bundle id.
APPSTORE_ENVIRONMENT=production
APPSTORE_BUNDLE_ID=<com.example.app>
# Apple root CA directory for REAL StoreKit JWS verification (subscription/storekit.py).
# The IN-CONTAINER path is PINNED by docker-compose.prod.yml (`environment: APPSTORE_ROOT_CERT_DIR=
# /etc/appstore-certs`), which bind-mounts the HOST dir `./certs/appstore` (-> /opt/<instance>/
# certs/appstore) read-only. So this `.env` value is INFORMATIONAL — compose overrides it; you do
# NOT need to set it here. To enable real verification, drop AppleRootCA-G3.cer (public,
# https://www.apple.com/certificateauthority/) into /opt/<instance>/certs/appstore on the server
# and restart api (see the §Apple root CA provisioning runbook at the bottom of this file).
# EMPTY dir -> _load_roots()=[] -> StoreKit stays test-mode / fail-closed (container starts fine).
APPSTORE_ROOT_CERT_DIR=/etc/appstore-certs

# --- StoreKit test-mode — MUST be false in prod (Q-007-1, TD-007) ------------
# Prod fail-closed: real JWS verification. Leave TEST_SECRET empty in prod.
STOREKIT_TEST_MODE=false
STOREKIT_TEST_SECRET=

# --- Billing (ADR-006) -------------------------------------------------------
SUBSCRIPTION_CREDITS_PER_PERIOD=1000

# --- Token purchase (ADR-015) — NOT a secret, but must match App Store Connect IAP -----
# Server-side mapping consumable productId -> credits (JSON). Unknown productId -> 422.
TOKEN_PRODUCTS={"tokens_1500":1500,"tokens_600":600,"tokens_250":250,"tokens_100":100}

# --- Adapty subscription webhook (ADR-029) -----------------------------------
# POST /v1/billing/adapty/webhook authorizes a static bearer secret
# (Authorization: Bearer <ADAPTY_WEBHOOK_SECRET>, constant-time compare like admin/preview).
#
# ADAPTY_WEBHOOK_SECRET — SECRET, high-entropy (>= 32 bytes), PER-INSTANCE, isolated from every
#   other secret. Empty => the endpoint returns 500 (mis-configured). NEVER commit a real value.
#   It MUST equal the value the operator sets in the Adapty dashboard webhook Authorization header.
#   CLONE NOTE (ADR-017 §Мульти-инстанс): a clone uses its OWN fresh secret — never share between
#   instances; the same fresh value also goes into that instance's Adapty dashboard.
#   Provision (per instance, ON THE SERVER — see §provisioning at bottom of this file):
#     openssl rand -hex 32   ->  /opt/<instance>/.env  ->  restart api  ->  Adapty UI (Bearer).
ADAPTY_WEBHOOK_SECRET=<set-per-instance, must match Adapty dashboard; openssl rand -hex 32>
# Adapty product -> credits map (JSON {vendor_product_id: tokens}); NOT a secret, but must match
# the Adapty product configuration. Empty {} => every event uses the fallback grant below.
ADAPTY_PRODUCT_TOKENS={"weekly_xxx":1000,"yearly_yyy":1000}
# Fallback grant (integer > 0) when vendor_product_id is absent from ADAPTY_PRODUCT_TOKENS.
# Separate from SUBSCRIPTION_CREDITS_PER_PERIOD (StoreKit path) for independent calibration.
ADAPTY_SUBSCRIPTION_TOKENS_GRANT=1000

# --- BYOK active model (ADR-016) ---------------------------------------------
BYOK_DEFAULT_MODEL=claude-sonnet-4-6

# --- Admin auth (ADR-009) — SECRET, isolated, high-entropy -------------------
ADMIN_API_SECRET=<openssl rand -base64 32>
# Previous secret kept valid during rotation (grace period); empty outside rotation.
ADMIN_API_SECRET_PREV=
ADMIN_RATE_LIMIT_PER_MIN=10
ADMIN_SIZE_LIMIT_BODY=8192

# --- Website builder / preview (ADR-010) — SECRET, isolated HMAC key --------
PREVIEW_URL_SECRET=<openssl rand -base64 32>
PREVIEW_URL_TTL_SECONDS=900
PREVIEW_MAX_FILE_BYTES=1048576
PREVIEW_MAX_PROJECT_BYTES=10485760
PREVIEW_MAX_FILES=200
MAX_SERVER_TOOL_ROUNDS=16

# --- Trusted reverse-proxy = the EXTERNAL Traefik (docs/05-security.md anti-spoofing) ----
# must-configure-before-launch: set to the docker network `web` subnet so per-IP rate limiting
# sees the real client IP from Traefik's X-Forwarded-For (not Traefik's own IP). Find the
# subnet ON THE SERVER:
#   docker network inspect web  ->  .[0].IPAM.Config[].Subnet  (typically 172.x.0.0/16)
# Empty => X-Forwarded-For is ignored and only the socket peer (Traefik) is seen — rate limit
# would then be per-Traefik-IP and effectively global (broken). See ADR-017.
TRUSTED_PROXY_IPS=<web-network-subnet-cidr, e.g. 172.18.0.0/16>
TRUSTED_PROXY_HOP_COUNT=1

# --- DB connection pool (per process) ----------------------------------------
# Effective conns ~= (DB_POOL_SIZE + DB_MAX_OVERFLOW) * gunicorn_workers(4) * replicas(1)
# = (10 + 5) * 4 * 1 = 60 < Postgres max_connections (100). Recompute if you scale workers/replicas.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- API documentation (R7) — hide schema in prod (prod-checklist, Q-007-1 group) --------
DOCS_ENABLED=false

# --- Hermes integration: client API key (ADR-044) ---------------------------
# Single client key for X-API-Key on the whole /v1/* client surface (Hermes integration).
# SECRET, high-entropy (>= 32 bytes), secret manager only, under redaction. PER-INSTANCE.
# Empty => the client surface is unavailable (always 401). NEVER commit a real value.
#   openssl rand -base64 32
CLIENT_API_KEY=<openssl rand -base64 32>
# Previous client key kept valid during rotation (grace period); empty outside rotation. SECRET.
CLIENT_API_KEY_PREV=

# --- Hermes runtime: per-user agent containers (ADR-046, 07-deployment.md §Hermes runtime) ---
# The control plane (api) provisions ONE Docker container + volume per user (the autonomous
# Hermes agent) and proxies /v1/agent/* to it (ADR-045). Requires Docker daemon access — see the
# `/var/run/docker.sock` mount + ⚠️ warning in docker-compose.prod.yml.
#
# HERMES_IMAGE — Docker image + PINNED tag of the Hermes RUNTIME instance image (this is the image
#   of the per-user instances, NOT the control-plane api image which is built on the server).
#   SELF-CONTAINED REQUIREMENT: this service ships ONLY this repo to the server. The Hermes runtime
#   is pulled from a PUBLIC REGISTRY by image ref (docker-py `containers.run(image=...)` auto-pulls
#   if absent) — it is NEVER built from external Hermes sources on the server. So put a PUBLIC,
#   PINNED registry ref here (NEVER `:latest`):
#     nousresearch/hermes-agent:<pinned-tag>     (or pin by digest: nousresearch/hermes-agent@sha256:...)
#   PREREQUISITE: the tag/digest must be pullable on the server (`docker pull <ref>`) BEFORE the
#   first /v1/agent/* request, OR pre-pulled into the daemon. PER-INSTANCE, PUBLIC (not a secret).
#   DEFAULT EMPTY => provisioning FAILS FAST (explicit misconfiguration rather than silently
#   pulling an unknown/`latest` image — src/app/hermes_runtime/manager.py).
#   Rollback (ADR-046): change this tag/digest + re-provision instances (deprovision/provision);
#   the per-user volume is preserved.
HERMES_IMAGE=nousresearch/hermes-agent:<pinned-tag>   # PUBLIC registry ref, PINNED (never :latest); e.g. nousresearch/hermes-agent:v1.0.0
# Dedicated docker network: control plane <-> Hermes instances. Instances do NOT publish a host
# port — reachable ONLY on this network, addressed by container DNS (hermes-user-<id>:8642).
# Declared `external: true` in docker-compose.prod.yml -> CREATE IT ONCE ON THE SERVER BEFORE the
# first deploy of this stack (otherwise `compose up`/`config` fails on the missing external net):
#   docker network create hermes-net
# DEFAULT `hermes-net`. PUBLIC, not a secret.
# MULTI-INSTANCE (Q-046-3): for MULTIPLE control planes on the shared Docker daemon, set a
#   PER-INSTANCE network (e.g. HERMES_DOCKER_NETWORK=avelyra-hermes-net) and create THAT on the
#   server, so each control plane only sees/reaches its own Hermes containers. Single control
#   plane -> leave the default.
HERMES_DOCKER_NETWORK=hermes-net
# Host root dir for per-user HERMES_HOME volumes; the manager mounts <HERMES_VOLUME_ROOT>/<user_id>
# into each instance at /opt/data (survives hibernation stop/start). DEFAULT /opt/data/hermes.
# ⚠️ MULTI-INSTANCE COLLISION (Q-046-3): the DEFAULT /opt/data/hermes is correct for a SINGLE
#   control plane. With MULTIPLE control planes on the SAME shared server, the per-user paths key
#   off user_id (a UUID) — distinct instances could in principle write under the same root. Set a
#   PER-INSTANCE root to isolate volumes by instance, e.g.:
#       HERMES_VOLUME_ROOT=/opt/data/avelyra/hermes   # on /opt/avelyra/.env
#   (container names hermes-user-<uuid> already carry per-user uniqueness; the volume ROOT is the
#   collision surface across control planes — isolate it per instance). PUBLIC, not a secret.
HERMES_VOLUME_ROOT=/opt/data/hermes
# Safe toolset written into each instance's config.yaml (platform_toolsets.api_server), comma-
# separated. DEFAULT excludes terminal/browser/code_execution/computer_use (05-security.md).
HERMES_DEFAULT_TOOLSET=web,file,vision,skills,todo
# Hibernation threshold (sec): a container idle longer than this is stopped by the reaper. 1800=30m.
HERMES_IDLE_TIMEOUT_SECONDS=1800
# Reaper poll interval (sec) in the api lifespan. 300=5m.
HERMES_REAPER_INTERVAL_SECONDS=300
# LLM provider/key/model used INSIDE each Hermes instance (its own env). Independent of the
# control plane's LLM_PROVIDER (ADR-033). HERMES_LLM_API_KEY is a SECRET (secret manager, redaction);
# empty => provisioning fails fast. Must match HERMES_LLM_PROVIDER.
HERMES_LLM_PROVIDER=anthropic
HERMES_LLM_API_KEY=<hermes_instance_llm_api_key>
# Default model of the Hermes instance (its LLM_MODEL); empty => the Hermes image's own default.
HERMES_MODEL=
# Generated API_SERVER_KEY length in bytes (CSPRNG; >=16 chars after encoding). 32 => 43-char token.
HERMES_API_KEY_BYTES=32
# Health-probe timeout to an instance (GET /health), seconds.
HERMES_HEALTH_TIMEOUT_SECONDS=5
# Proxy / SSE-relay timeouts to a Hermes instance (ADR-045 §6).
HERMES_PROXY_TIMEOUT_SECONDS=30
HERMES_SSE_CONNECT_TIMEOUT_SECONDS=10
# Stale provisioning-row recovery threshold (TD-031), seconds.
HERMES_PROVISIONING_STALE_SECONDS=120
# Cold-start readiness-gate (ADR-056). After `docker run`, the control plane polls the per-user
# instance's GET /health (Bearer) until 200 BEFORE marking it `running` (Hermes image cold-start
# ~30-40s on the ~5.3 GB image). Timeout => container cleanup + 502 (never a `running` row on an
# unready container). INVARIANT (validated fail-fast in config.py on start):
#   HERMES_PROVISIONING_STALE_SECONDS (120) > HERMES_PROVISION_READY_TIMEOUT_SECONDS (90).
# PUBLIC, per-instance, not secrets.
HERMES_PROVISION_READY_TIMEOUT_SECONDS=90
HERMES_PROVISION_READY_INTERVAL_SECONDS=2
# Volume ownership (ADR-056 §4). Passed to each Hermes instance as env HERMES_UID/HERMES_GID; the
# image's s6 stage2 runs usermod/groupmod + chown /opt/data to these values. They MUST equal the
# uid/gid of the api container process (Dockerfile: useradd --uid 10001 --gid 10001; USER
# 10001:10001), which writes config.yaml into the per-user volume — otherwise PermissionError(13)
# on a reuse-provision (after hibernation/replay/redeploy). Keep in sync with the api service's
# uid/gid in docker-compose.prod.yml. PUBLIC, not secrets. See 07-deployment.md prod-checklist.
HERMES_UID=10001
HERMES_GID=10001

# --- Agent usage-based billing (ADR-047) -------------------------------------
# Credits per 1000 tokens for /v1/agent/* runs:
#   amount = ceil(input/1000*CREDITS_PER_1K_INPUT + output/1000*CREDITS_PER_1K_OUTPUT), floor 1 on
#   any non-zero usage. CALIBRATE to provider cost before taking traffic (Q-047-1). PUBLIC,
#   per-instance, not secrets.
CREDITS_PER_1K_INPUT=1.0
CREDITS_PER_1K_OUTPUT=5.0

# --- Observability -----------------------------------------------------------
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=
# SECRET: if set, GET /metrics requires X-Scrape-Token == this value (else 403).
METRICS_SCRAPE_TOKEN=<openssl rand -base64 32>

# =============================================================================
# ADAPTY_WEBHOOK_SECRET provisioning (per instance, ADR-029) — operator runbook.
# Run ON THE SERVER (87.239.135.154, root). Per-instance: repeat for EACH instance
# (broadnova /opt/claude-ios, avelyra /opt/avelyra, …) with its OWN fresh secret.
#
#   1. Generate a fresh high-entropy secret for THIS instance:
#        SECRET=$(openssl rand -hex 32)
#   2. Write it into the instance .env (replace the placeholder line; never commit .env):
#        cd /opt/<instance>            # e.g. /opt/claude-ios or /opt/avelyra
#        # set ADAPTY_WEBHOOK_SECRET=$SECRET in /opt/<instance>/.env
#   3. Restart api to pick up the new env (migrate not needed for this var):
#        docker compose -p <instance> -f docker-compose.prod.yml --env-file .env up -d --no-build api
#   4. In the Adapty Dashboard for THIS instance's app: configure the webhook URL
#        https://<SERVICE_DOMAIN>/v1/billing/adapty/webhook
#      and set the Authorization header to:  Bearer <the same $SECRET>.
#   5. Verify: a 401 means the bearer values differ; a 500 means the env secret is empty/not loaded.
#
# Do NOT reuse one secret across instances. Do NOT store the real secret in the repo or image.
# =============================================================================

# =============================================================================
# Apple root CA provisioning for REAL StoreKit JWS verification — operator runbook.
# Run ON THE SERVER (87.239.135.154, root). ENABLE ONLY ON avelyra (/opt/avelyra) for now —
# broadnova (/opt/claude-ios), orvianix (/opt/orvianix) and veltrio (/opt/veltrio) keep an EMPTY
# certs dir and stay in test-mode / fail-closed (the empty bind-mount is benign; the container
# starts normally).
#
#   1. Ensure the cert dir exists for THIS instance (it ships in the repo via certs/appstore/.gitkeep,
#      so `git pull` already created it — this is just a safety check):
#        cd /opt/avelyra
#        mkdir -p certs/appstore
#   2. Download Apple's PUBLIC root CA (AppleRootCA-G3, DER .cer) into it:
#        curl -fsSL -o certs/appstore/AppleRootCA-G3.cer \
#             https://www.apple.com/appleca/AppleRootCA-G3.cer
#      (source page: https://www.apple.com/certificateauthority/). Optional integrity check:
#        openssl x509 -inform DER -in certs/appstore/AppleRootCA-G3.cer -noout -subject -issuer
#        # expect subject/issuer CN = "Apple Root CA - G3" (self-signed root).
#   3. Make sure STOREKIT_TEST_MODE is NOT true on this instance (.env): real path requires
#        STOREKIT_TEST_MODE=false  (and STOREKIT_TEST_SECRET empty). Prod default is already false.
#   4. Recreate api to mount the now-populated dir (mounts are fixed at container create time —
#      a running container will NOT see a newly-added file without recreate):
#        docker compose -p avelyra -f docker-compose.prod.yml --env-file .env up -d --no-build api
#   5. Verify the root loaded (WITHOUT a real Apple transaction):
#      (a) the api container can read the cert as the non-root user:
#            docker exec avelyra-api-1 ls -l /etc/appstore-certs
#            docker exec avelyra-api-1 sh -c 'head -c 0 /etc/appstore-certs/AppleRootCA-G3.cer && echo READABLE'
#      (b) a self-minted HS256 "transaction" now FAILS with 422 (test-mode is OFF) — same as a
#          forged real transaction. POST a dummy HS256 JWS to the verify endpoint and expect 422
#          ("StoreKit JWS signature invalid"); previously (test-mode on) it would 200. A real
#          ES256/x5c transaction from the app then verifies against the loaded root.
#      (c) the readiness/health probe stays green (GET /ready, GET /health) — loading roots at
#          startup must not crash the app:
#            docker inspect avelyra-api-1 --format '{{.State.Health.Status}}'   # -> healthy
#
# Do NOT commit the .cer to the repo (provisioned on the server). It is PUBLIC, but the source of
# truth is Apple; keep the host dir as the only place it lives. broadnova/orvianix/veltrio: leave EMPTY.
# =============================================================================

# =============================================================================
# §claude-hermes — NEW INDEPENDENT INSTANCE clone block (ADR-017 §Мульти-инстанс, ADR-046).
# -----------------------------------------------------------------------------------------------
# claude-hermes is a SEPARATE control-plane instance (Hermes-per-user agent runtime) — NOT a rename
# of claude-ios. It deploys to /opt/claude-hermes on the SAME shared server behind the SAME external
# Traefik, with FULLY ISOLATED state (own compose project, own volumes, own DB creds, own Hermes
# docker-network + volume root, own secrets). The live broadnova.shop (claude-ios) is UNAFFECTED.
#
# HOW TO USE: on the server, copy THIS file to /opt/claude-hermes/.env, then REPLACE the values in
# the main template ABOVE with the per-instance values below (and fill every <placeholder> from the
# secret manager — NEVER commit real secrets). Deploy with `-p claude-hermes` (the CI INSTANCES loop
# already includes `claude-hermes:claude-hermes`). Generate every secret freshly:  openssl rand -base64 32
#
#   # --- identity & routing -------------------------------------------------------------------
#   COMPOSE_PROJECT_NAME=claude-hermes
#   SERVICE_DOMAIN=<claude-hermes-domain>            # e.g. claudehermes.example — own A-record -> server IP
#   TRAEFIK_CERTRESOLVER=le                          # same shared Traefik resolver
#
#   # --- database / redis (OWN fresh creds; isolated volume per compose project) ---------------
#   POSTGRES_USER=<ch_db_user>
#   POSTGRES_PASSWORD=<ch_db_password>               # fresh; never reuse claude-ios creds
#   POSTGRES_DB=<ch_db_name>
#   APP_RW_PASSWORD=<ch_app_rw_password>
#   APP_MIGRATE_PASSWORD=<ch_app_migrate_password>
#   DATABASE_URL=postgresql+asyncpg://app_rw:<ch_app_rw_password>@postgres:5432/<ch_db_name>
#   DATABASE_URL_MIGRATE=postgresql+asyncpg://app_migrate:<ch_app_migrate_password>@postgres:5432/<ch_db_name>
#   REDIS_URL=redis://redis:6379/0
#
#   # --- client + LLM secrets (own, per-instance) ---------------------------------------------
#   CLIENT_API_KEY=<ch_client_api_key>
#   ANTHROPIC_API_KEY=<ch_anthropic_api_key>         # or set LLM_PROVIDER=openai + OPENAI_API_KEY
#   KMS_LOCAL_MASTER_KEY=<ch_base64_32_random_bytes> # fresh; BYOK ciphertext is NOT portable
#   ADMIN_API_SECRET=<ch_admin_secret>
#   PREVIEW_URL_SECRET=<ch_preview_secret>
#   ADAPTY_WEBHOOK_SECRET=<ch_adapty_secret>
#   METRICS_SCRAPE_TOKEN=<ch_metrics_token>
#   JWT_ISSUER=https://<claude-hermes-domain>
#   JWT_AUDIENCE=claude-hermes
#
#   # --- Hermes runtime: OWN dedicated network + volume root (multi-instance isolation, Q-046-3) -
#   HERMES_IMAGE=nousresearch/hermes-agent:<pinned-tag>   # PUBLIC registry ref, PINNED; never :latest
#   HERMES_DOCKER_NETWORK=claude-hermes-hermes-net        # CREATE on server: docker network create claude-hermes-hermes-net
#   HERMES_VOLUME_ROOT=/opt/data/claude-hermes/hermes     # per-instance volume root (isolate from claude-ios)
#   HERMES_LLM_PROVIDER=anthropic
#   HERMES_LLM_API_KEY=<ch_hermes_instance_llm_api_key>   # SECRET; empty => provisioning fails fast
#
#   # --- trusted proxy = web subnet (same as other instances) ---------------------------------
#   TRUSTED_PROXY_IPS=<web-network-subnet-cidr>
#   DOCS_ENABLED=false
#
# PRE-DEPLOY (server, ONCE, before the first claude-hermes deploy — ADR-017/ADR-046):
#   docker network create web                          # shared (already created)
#   docker network create claude-hermes-hermes-net     # this instance's dedicated Hermes network
#   docker pull nousresearch/hermes-agent:<pinned-tag> # make the runtime image pullable
#   mkdir -p /opt/data/claude-hermes/hermes            # per-instance Hermes volume root
# Then: clone the repo into /opt/claude-hermes, drop this .env + .secrets/ (RSA JWT pair), and the
# CI deploy (INSTANCES loop) handles build -> migrate -> up -> readiness for `claude-hermes`.
# =============================================================================

# =============================================================================
# §avorelio — DEDICATED server (87.239.135.156) + OUR self-hosted Traefik (ADR-057).
# -----------------------------------------------------------------------------------------------
# This is deploy-target №2 for claude-hermes: a SEPARATE, DEDICATED Linux server (87.239.135.156,
# domain avorelio.shop) where the reverse-proxy + TLS is OUR OWN Traefik container, merged in via
# the docker-compose.avorelio.yml OVERLAY (NOT the external /opt/edge Traefik of broadnova .154).
# It is INDEPENDENT of the broadnova .154 server (same code/repo; the target is operational).
#
# HOW TO USE: on .156, copy THIS file to /opt/claude-hermes/.env and fill it like the §claude-hermes
# clone block ABOVE (own fresh DB/LLM/client/JWT secrets — NEVER reuse broadnova's; never commit
# real secrets), PLUS the avorelio-specific keys below. Deploy via the `deploy-avorelio` job
# (ci.yml on push:main, or deploy.yml manual) with the merged compose `-f` set:
#   docker compose -f docker-compose.prod.yml -f docker-compose.avorelio.yml --env-file .env <cmd>
#
#   # --- identity & routing (avorelio) --------------------------------------------------------
#   COMPOSE_PROJECT_NAME=claude-hermes               # container/volume/network prefix -> claude-hermes_web etc.
#   SERVICE_DOMAIN=avorelio.shop                      # Traefik Host router + ACME cert + app preview URL
#   TRAEFIK_CERTRESOLVER=le                           # resolver name declared in OUR Traefik command flags
#   # ACME_EMAIL — MANDATORY on .156 (self-hosted Traefik, ADR-057 §2). Let's Encrypt expiry
#   #   notifications. EMPTY => Traefik FAIL-FAST on start (compose `:?` substitution in the
#   #   --certificatesresolvers.le.acme.email flag). Used ONLY on .156 (NOT on broadnova .154,
#   #   where ACME is the external Traefik's job). PUBLIC, not a secret.
#   ACME_EMAIL=<acme-email-placeholder>               # e.g. ops@avorelio.shop — your real ACME contact
#   JWT_ISSUER=https://avorelio.shop
#   JWT_AUDIENCE=claude-hermes
#
#   # --- Hermes runtime: OWN UID/GID (ADR-056; MUST equal the api container uid/gid) ----------
#   HERMES_UID=10001
#   HERMES_GID=10001
#   HERMES_IMAGE=nousresearch/hermes-agent:<pinned-tag>   # PUBLIC registry ref, PINNED; NEVER :latest
#   HERMES_DOCKER_NETWORK=hermes-net                  # external; CREATE on .156: docker network create hermes-net
#   HERMES_VOLUME_ROOT=/opt/data/hermes               # per-server Hermes volume root (mkdir -p before deploy)
#   HERMES_LLM_PROVIDER=custom                         # CONCRETE provider from the image allowlist (NOT openai/auto)
#   HERMES_LLM_BASE_URL=<hermes-llm-base-url>          # REQUIRED for custom/azure-foundry (model.base_url)
#   HERMES_MODEL=<bare-model-name>                     # bare model id (no provider prefix); MUST be non-empty
#   HERMES_LLM_API_KEY=<hermes_instance_llm_api_key>   # SECRET; empty => provisioning fails fast; matches provider
#
#   # --- trusted reverse-proxy = OUR internal `web` subnet (ADR-057 §4) -----------------------
#   # On .156 `web` is INTERNAL (created by compose as claude-hermes_web). Find its subnet AFTER
#   # the first `up` and set TRUSTED_PROXY_IPS to it, else per-IP rate limiting sees OUR Traefik's
#   # IP (broken). docker network inspect claude-hermes_web -> .[0].IPAM.Config[].Subnet (172.x.0.0/16).
#   TRUSTED_PROXY_IPS=<our-web-network-subnet-cidr, e.g. 172.20.0.0/16>
#   DOCS_ENABLED=false
#
# REMINDER — also set ALL the secrets/keys exactly as in the §claude-hermes clone block above
# (NEVER commit real values; use the secret manager):
#   - DB roles: POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB, APP_RW_PASSWORD,
#     APP_MIGRATE_PASSWORD, DATABASE_URL (app_rw), DATABASE_URL_MIGRATE (app_migrate), REDIS_URL.
#   - Client/admin/preview/billing: CLIENT_API_KEY, ADMIN_API_SECRET, PREVIEW_URL_SECRET,
#     ADAPTY_WEBHOOK_SECRET, METRICS_SCRAPE_TOKEN, KMS_LOCAL_MASTER_KEY.
#   - HERMES_IMAGE must be a PINNED registry ref (NEVER :latest).
#
# PRE-DEPLOY on .156 (root, ONCE, before the first deploy — ADR-057 §6):
#   # DNS: A-record avorelio.shop -> 87.239.135.156 MUST exist (ACME HTTP-01 needs port 80 reachable).
#   docker network create hermes-net                  # external Hermes net (web is created by compose — DO NOT create)
#   mkdir -p /opt/data/hermes                          # Hermes per-user volume root
#   docker pull nousresearch/hermes-agent:<pinned-tag> # make the runtime image pullable
#   # clone the repo into /opt/claude-hermes, drop this .env + .secrets/ (RSA JWT pair).
# Then: the `deploy-avorelio` CI job handles build -> migrate -> up -> readiness; OUR Traefik
# issues the avorelio.shop TLS cert on the first deploy (HTTP-01). The public smoke is NON-FATAL.
# =============================================================================
